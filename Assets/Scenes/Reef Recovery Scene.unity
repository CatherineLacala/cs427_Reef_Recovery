    - target: {fileID: 1000011759684950, guid: c1621f4dd1e8c2748a5a423aa7736d55, type: 3}
      propertyPath: m_IsActive
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 1000012607288206, guid: c1621f4dd1e8c2748a5a423aa7736d55, type: 3}
      propertyPath: m_IsActive
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 1000011531200472, guid: c1621f4dd1e8c2748a5a423aa7736d55, type: 3}
      propertyPath: m_IsActive
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 1000011884111856, guid: c1621f4dd1e8c2748a5a423aa7736d55, type: 3}
      propertyPath: m_IsActive
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 114000011111918770, guid: c1621f4dd1e8c2748a5a423aa7736d55,
        type: 3}
      propertyPath: m_Text
      value: "GOAL: Our project aims to visualize coral reef health as a dynamic system
        affected by human intervention. Instead of focusing solely on reef destruction,
        the project has users apply different restoration strategies which affect
        the reef\u2019s appearance.\r\n\nHow this Project Helps Advance Research\r\n-
        Translates complicated marine ecology data into experiential understanding\r\n-
        Provides insight to how people understand ecosystem resilience when changes
        are experienced\r\n- Supports previous research about how immersive visualizations
        improve comprehension of long-term environmental processes\r\n\nContribution
        to SDG 14: Life Below Water\r\n- Shows cause-and-effect relationships between
        human behavior and reef health\r\n- Encourages and demonstrates actionable
        solutions such as implementing reef acoustic playback systems (RAPS)\r"
      objectReference: {fileID: 0}
    - target: {fileID: 114000011641407824, guid: c1621f4dd1e8c2748a5a423aa7736d55,
        type: 3}
      propertyPath: m_Text
      value: 'CS 427 - Creative Coding

        Spring 2026

        University of Illinois at Chicago'
      objectReference: {fileID: 0}
    - target: {fileID: 114000010541511360, guid: c1621f4dd1e8c2748a5a423aa7736d55,
        type: 3}
      propertyPath: m_Text
      value: Reef Recovery
      objectReference: {fileID: 0}
    - target: {fileID: 114000011468825520, guid: c1621f4dd1e8c2748a5a423aa7736d55,
        type: 3}
      propertyPath: m_Text
      value: "Catherine Lacala\nEvelyn Johnson\nJackie Mei\r\nBrian Wilk"
      objectReference: {fileID: 0}
    - target: {fileID: 114000010683909002, guid: c1621f4dd1e8c2748a5a423aa7736d55,
        type: 3}
      propertyPath: m_Text
      value: "Based on our research, there are new studies that highlight the influence
        of using RAPS to enhance the settlement of coral larvae, which are fundamental
        in sustaining coral reefs. \n\nRAPS helps support both healthy and reefs that
        are undergoing restoration using acoustic reef soundscapes such as ocean chirps
        and signals from the antenna of spiny lobsters. \n\nThis immersive experience
        offers insight into the potential of some reef restoration strategies."
      objectReference: {fileID: 0}
    m_RemovedComponents: []
  m_SourcePrefab: {fileID: 100100000, guid: c1621f4dd1e8c2748a5a423aa7736d55, type: 3}
